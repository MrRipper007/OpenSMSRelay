<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Block all cleartext (plain HTTP/SMTP) traffic app-wide.
        All SMTP connections must use SSL or STARTTLS (handled in EmailForwarder).
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
