<?xml version="1.0" encoding="utf-8"?>
<!-- allowBackup is false in the manifest; these rules are a defence-in-depth
     safeguard in case that flag is ever accidentally changed. -->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
